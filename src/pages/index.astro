---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import mascotLanding from '../assets/mascot/mascot-landing.png';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home" description="A personal, living cookbook by Julius.">
  <div class="landing">
    <div class="landing-mascot">
      <Image src={mascotLanding} alt="Juli" width={520} />
    </div>
    <div>
      <h1>Juli's Cookbook</h1>
      <p class="landing-sub">The recipes I love to cook - for the people I love to cook for.</p>
    </div>
    <a href={`${base}recipes`} class="btn">Browse recipes</a>
  </div>
</BaseLayout>
