<!-- Chef-hat bust — used in the nav/logo -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 96" fill="none" aria-hidden="true">
  <!-- Chef hat puff -->
  <ellipse cx="40" cy="22" rx="24" ry="20" fill="#FDFAF5" stroke="#DDD0BC" stroke-width="1.2"/>
  <!-- Hat band -->
  <rect x="16" y="36" width="48" height="10" rx="2" fill="white" stroke="#DDD0BC" stroke-width="1.2"/>
  <!-- Head -->
  <circle cx="40" cy="66" r="28" fill="#F4C89A"/>
  <!-- Hair peeking under hat band -->
  <clipPath id="lhc"><circle cx="40" cy="66" r="28"/></clipPath>
  <rect x="14" y="43" width="52" height="9" fill="#D4A843" clip-path="url(#lhc)"/>
  <!-- Ears -->
  <ellipse cx="12" cy="68" rx="6" ry="8" fill="#F4C89A"/>
  <ellipse cx="68" cy="68" rx="6" ry="8" fill="#F4C89A"/>
  <!-- Brows (slight furrow) -->
  <path d="M 26 59 Q 31 56.5 36 59" stroke="#8B5E28" stroke-width="1.8" stroke-linecap="round"/>
  <path d="M 44 59 Q 49 56.5 54 59" stroke="#8B5E28" stroke-width="1.8" stroke-linecap="round"/>
  <!-- Eyes -->
  <ellipse cx="32" cy="66" rx="5" ry="5.5" fill="#2A2A2A"/>
  <ellipse cx="48" cy="66" rx="5" ry="5.5" fill="#2A2A2A"/>
  <circle cx="34" cy="64" r="1.5" fill="white"/>
  <circle cx="50" cy="64" r="1.5" fill="white"/>
  <!-- Mouth (deadpan slight downward) -->
  <path d="M 34 78 Q 40 80 46 78" stroke="#8B5E28" stroke-width="1.8" stroke-linecap="round"/>
</svg>
