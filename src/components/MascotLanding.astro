<!-- Full body character holding a steaming bowl — landing page hero -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 240 380" fill="none" aria-label="Mascot holding a bowl of food" role="img">

  <!-- ── Legs ── -->
  <rect x="82" y="262" width="28" height="80" rx="12" fill="#4A5A40"/>
  <rect x="130" y="262" width="28" height="80" rx="12" fill="#4A5A40"/>
  <!-- Shoes -->
  <ellipse cx="96" cy="342" rx="18" ry="9" fill="#2C2820"/>
  <ellipse cx="144" cy="342" rx="18" ry="9" fill="#2C2820"/>

  <!-- ── Torso ── -->
  <path d="M 72 180 Q 64 200 64 240 Q 64 270 80 272 L 160 272 Q 176 270 176 240 Q 176 200 168 180 Z"
        fill="#6B7F5E"/>

  <!-- ── Arms (bent, holding bowl) ── -->
  <!-- Left arm -->
  <path d="M 72 195 Q 42 220 38 268" stroke="#F4C89A" stroke-width="22" stroke-linecap="round" fill="none"/>
  <!-- Right arm -->
  <path d="M 168 195 Q 198 220 202 268" stroke="#F4C89A" stroke-width="22" stroke-linecap="round" fill="none"/>
  <!-- Hands holding bowl underside -->
  <ellipse cx="38" cy="272" rx="16" ry="12" fill="#F4C89A"/>
  <ellipse cx="202" cy="272" rx="16" ry="12" fill="#F4C89A"/>

  <!-- ── Bowl ── -->
  <path d="M 42 268 Q 42 308 120 308 Q 198 308 198 268 Z" fill="#A07820"/>
  <ellipse cx="120" cy="268" rx="78" ry="20" fill="#C49A30"/>
  <!-- Contents (tofu cubes + sauce colour) -->
  <ellipse cx="120" cy="264" rx="62" ry="14" fill="#C05828" opacity="0.85"/>
  <rect x="95" y="250" width="14" height="14" rx="2" fill="#FDFAF5" opacity="0.8"/>
  <rect x="116" y="253" width="12" height="12" rx="2" fill="#FDFAF5" opacity="0.8"/>
  <rect x="136" y="250" width="13" height="13" rx="2" fill="#FDFAF5" opacity="0.75"/>
  <!-- Steam wisps -->
  <path d="M 88 255 Q 84 242 88 230 Q 92 218 88 205" stroke="#DDD0BC" stroke-width="2.5" stroke-linecap="round" opacity="0.65"/>
  <path d="M 120 250 Q 116 237 120 225 Q 124 213 120 200" stroke="#DDD0BC" stroke-width="2.5" stroke-linecap="round" opacity="0.65"/>
  <path d="M 152 255 Q 148 242 152 230 Q 156 218 152 205" stroke="#DDD0BC" stroke-width="2.5" stroke-linecap="round" opacity="0.65"/>

  <!-- ── Neck ── -->
  <rect x="108" y="168" width="24" height="20" rx="6" fill="#F4C89A"/>

  <!-- ── Head ── -->
  <circle cx="120" cy="100" r="78" fill="#F4C89A"/>
  <!-- Ears -->
  <ellipse cx="42" cy="103" rx="15" ry="19" fill="#F4C89A"/>
  <ellipse cx="198" cy="103" rx="15" ry="19" fill="#F4C89A"/>

  <!-- Hair (blonde buzz cut — clipped to head shape) -->
  <defs>
    <clipPath id="mhc">
      <circle cx="120" cy="100" r="78"/>
    </clipPath>
  </defs>
  <!-- Hair covers top ~38% of the head, thinner at temples (receding) -->
  <ellipse cx="120" cy="38" rx="74" ry="52" fill="#D4A843" clip-path="url(#mhc)"/>
  <!-- Hairline fade — slightly lighter strip at the edge of the buzz cut -->
  <ellipse cx="120" cy="70" rx="60" ry="12" fill="#C89A30" opacity="0.35" clip-path="url(#mhc)"/>

  <!-- Brows (slight inward furrow — Nara's deadpan) -->
  <path d="M 92 82 Q 100 78 108 83" stroke="#8B5E28" stroke-width="3" stroke-linecap="round"/>
  <path d="M 132 83 Q 140 78 148 82" stroke="#8B5E28" stroke-width="3" stroke-linecap="round"/>

  <!-- Eyes -->
  <ellipse cx="100" cy="100" rx="10" ry="11" fill="#2A2A2A"/>
  <ellipse cx="140" cy="100" rx="10" ry="11" fill="#2A2A2A"/>
  <!-- Eye highlights -->
  <circle cx="104" cy="96" r="3" fill="white"/>
  <circle cx="144" cy="96" r="3" fill="white"/>

  <!-- Nose (subtle) -->
  <path d="M 120 112 Q 115 120 120 122" stroke="#D4A870" stroke-width="2" stroke-linecap="round"/>

  <!-- Mouth (slight downward curve — not sad, just focused) -->
  <path d="M 107 137 Q 120 140 133 137" stroke="#8B5E28" stroke-width="2.5" stroke-linecap="round"/>

</svg>
