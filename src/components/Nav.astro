---
import MascotLogo from './MascotLogo.astro';

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

function isActive(href: string) {
  if (href === base || href === base.replace(/\/$/, '')) {
    return path === base || path === base.replace(/\/$/, '');
  }
  return path.startsWith(href);
}
---

<header class="site-header">
  <a href={base} class="logo-link">
    <MascotLogo />
    Juli's Cookbook
  </a>
  <nav>
    <a href={`${base}recipes`} class={isActive(`${base}recipes`) ? 'active' : ''}>Recipes</a>
    <a href={`${base}note`}    class={isActive(`${base}note`)    ? 'active' : ''}>A note to you</a>
    <a href={`${base}about`}   class={isActive(`${base}about`)   ? 'active' : ''}>About</a>
  </nav>
</header>
