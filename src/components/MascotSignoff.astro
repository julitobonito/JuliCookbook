<!-- Small sign-off character — appears at end of each recipe -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 180" fill="none" aria-hidden="true">

  <!-- Body -->
  <path d="M 52 118 Q 46 130 46 155 L 114 155 Q 114 130 108 118 Z" fill="#6B7F5E"/>

  <!-- Right arm raised (wave) -->
  <path d="M 108 125 Q 130 108 138 90" stroke="#F4C89A" stroke-width="16" stroke-linecap="round" fill="none"/>
  <circle cx="138" cy="88" r="10" fill="#F4C89A"/>

  <!-- Left arm (resting) -->
  <path d="M 52 128 Q 34 140 32 152" stroke="#F4C89A" stroke-width="16" stroke-linecap="round" fill="none"/>

  <!-- Legs -->
  <rect x="60" y="152" width="18" height="22" rx="8" fill="#4A5A40"/>
  <rect x="82" y="152" width="18" height="22" rx="8" fill="#4A5A40"/>

  <!-- Head -->
  <circle cx="80" cy="70" r="52" fill="#F4C89A"/>

  <!-- Ears -->
  <ellipse cx="28" cy="72" rx="10" ry="13" fill="#F4C89A"/>
  <ellipse cx="132" cy="72" rx="10" ry="13" fill="#F4C89A"/>

  <!-- Hair -->
  <defs>
    <clipPath id="shc"><circle cx="80" cy="70" r="52"/></clipPath>
  </defs>
  <ellipse cx="80" cy="30" rx="49" ry="35" fill="#D4A843" clip-path="url(#shc)"/>

  <!-- Brows -->
  <path d="M 58 57 Q 64 54 70 57" stroke="#8B5E28" stroke-width="2" stroke-linecap="round"/>
  <path d="M 90 57 Q 96 54 102 57" stroke="#8B5E28" stroke-width="2" stroke-linecap="round"/>

  <!-- Eyes — one slightly squinting (happy) -->
  <ellipse cx="66" cy="68" rx="7" ry="7.5" fill="#2A2A2A"/>
  <ellipse cx="94" cy="68" rx="7" ry="7.5" fill="#2A2A2A"/>
  <circle cx="69" cy="65" r="2" fill="white"/>
  <circle cx="97" cy="65" r="2" fill="white"/>

  <!-- Mouth (small upward curve — rare smile) -->
  <path d="M 70 90 Q 80 95 90 90" stroke="#8B5E28" stroke-width="2" stroke-linecap="round"/>

</svg>
