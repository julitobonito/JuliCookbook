---
import type { CollectionEntry } from 'astro:content';

interface Props {
  recipe: CollectionEntry<'recipes'>;
}

const { recipe } = Astro.props;
const { title, description, image, diet, mealType, cuisine, time } = recipe.data;
const base = import.meta.env.BASE_URL;
const href = `${base}recipes/${recipe.slug}`;

// Cuisine placeholder colours for cards without photos
const placeholderEmoji: Record<string, string> = {
  Sichuan: '🌶️', Italian: '🍝', French: '🍫',
  Asian: '🥢', 'Middle Eastern': '🫙',
};
const emoji = placeholderEmoji[cuisine] ?? '🍽️';
---

<a
  class="recipe-card"
  href={href}
  data-recipe-card
  data-diet={diet.join(' ')}
  data-meal-type={mealType}
  data-cuisine={cuisine}
  data-time={time}
>
  {image
    ? <img class="card-image" src={image} alt={title} loading="lazy" />
    : <div class="card-image-placeholder" style={`background:var(--border)`}>{emoji}</div>
  }
  <div class="card-body">
    <div class="card-meta">
      <span>{cuisine}</span>
      <span class="card-meta-dot">·</span>
      <span>{time}</span>
    </div>
    <h2 class="card-title">{title}</h2>
    <div class="card-tags">
      {diet.map(d => <span class={`tag tag-${d}`}>{d}</span>)}
      <span class={`tag tag-${mealType}`}>{mealType}</span>
    </div>
    <p class="card-desc">{description}</p>
  </div>
</a>
